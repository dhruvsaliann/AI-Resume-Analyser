{
  "buildCommand": "pnpm --filter @workspace/resume-analyzer run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/resume-analyzer/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
